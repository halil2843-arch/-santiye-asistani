# Veritabanı
DATABASE_URL=sqlite+aiosqlite:///./santiye.db

# Güvenlik — güçlü, rastgele bir değer üretin:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=BURAYA_GUCLU_BIR_ANAHTAR_YAZIN

# Geliştirme modunda True yapın
DEBUG=true

# Groq API — https://console.groq.com
GROQ_API_KEY=gsk_...

# LLM Modeli
DEFAULT_MODEL=llama-3.3-70b-versatile

# Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# Twilio WhatsApp Sandbox — https://console.twilio.com
TWILIO_AUTH_TOKEN=...
TWILIO_ACCOUNT_SID=AC...
# Sandbox numarası (değiştirme):
TWILIO_WHATSAPP_FROM=+14155238886

# Dosya dizinleri (varsayılan değerler çalışır)
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs

# CORS (geliştirmede * bırakın)
CORS_ORIGINS=*
