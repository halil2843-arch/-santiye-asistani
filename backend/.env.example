# =============================================================================
# Şantiye Asistanı — Ortam Değişkenleri Şablonu
# Bu dosyayı kopyalayın: cp .env.example .env
# .env dosyasını ASLA git'e commit etmeyin!
# =============================================================================

# ===== GELİŞTİRME (Varsayılan değerler) =====
DATABASE_URL=sqlite+aiosqlite:///./santiye.db
DEBUG=true
CORS_ORIGINS=*

# ===== PRODUCTION (Aşağıdaki değerleri deploy öncesi değiştir) =====
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost/santiye
# DEBUG=false
# CORS_ORIGINS=https://santiyeasistani.com,https://www.santiyeasistani.com

# =============================================================================
# GEREKLİ API ANAHTARLARI
# Bu değerlerin tamamı production'da doldurulmalıdır.
# =============================================================================

# Güvenlik — Güçlü, rastgele bir değer üretin (32+ karakter):
#   python -c "import secrets; print(secrets.token_hex(32))"
# UYARI: Varsayılan değer production'da başlatmayı engeller (config.py validator)
SECRET_KEY=BURAYA-GUCLU-BIR-SECRET-KEY-YAZ

# Groq API — https://console.groq.com
GROQ_API_KEY=

# LLM Modeli
DEFAULT_MODEL=llama-3.3-70b-versatile

# Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Twilio WhatsApp — https://console.twilio.com
TWILIO_AUTH_TOKEN=
TWILIO_ACCOUNT_SID=
# Sandbox numarası (geliştirme). Production'da gerçek numara girin.
TWILIO_WHATSAPP_FROM=+14155238886

# Hava Durumu (OpenWeatherMap Free API)
# https://openweathermap.org/api'den ücretsiz key alınabilir.
# Boş bırakılırsa mock veri döner.
OPENWEATHER_API_KEY=

# =============================================================================
# TOKEN SÜRELERİ
# =============================================================================

# Access token (dakika) — production'da kısa tutun (örn. 15 veya 30)
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Refresh token (gün)
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# DOSYA DEPOLAMA (Varsayılan değerler lokal disk için çalışır)
# Production'da S3/R2 bucket'a geçmek önerilir.
# =============================================================================
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs
